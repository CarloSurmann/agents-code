# =============================================================================
# Customer Secrets — NEVER commit this file
# =============================================================================
# Copy to .env and fill in the values for this customer.
# These are loaded automatically by serve.py.
# =============================================================================

# --- Anthropic API -----------------------------------------------------------
ANTHROPIC_API_KEY=

# --- WhatsApp (Meta Cloud API) -----------------------------------------------
# Only needed if channel.type = whatsapp
WHATSAPP_PHONE_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_ALLOWED_NUMBERS=
WHATSAPP_CALLBACK_URL=

# --- Microsoft Teams (Bot Framework) -----------------------------------------
# Only needed if channel.type = teams
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=
TEAMS_TENANT_ID=

# --- Telegram ----------------------------------------------------------------
# Only needed if channel.type = telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Slack -------------------------------------------------------------------
# Only needed if channel.type = slack
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# --- Fatture in Cloud --------------------------------------------------------
# Only needed if accounting.provider = fattureincloud
FIC_ACCESS_TOKEN=
FIC_COMPANY_ID=

# --- Exact Online ------------------------------------------------------------
# Only needed if accounting.provider = exact_online
EXACT_CLIENT_ID=
EXACT_CLIENT_SECRET=
EXACT_DIVISION=
EXACT_COUNTRY=nl

# --- Gmail -------------------------------------------------------------------
# Only needed if email.provider = gmail
GMAIL_USER_EMAIL=
GMAIL_CREDENTIALS_PATH=./secrets/credentials.json
GMAIL_TOKEN_PATH=./secrets/gmail_token.json

# --- Outlook -----------------------------------------------------------------
# Only needed if email.provider = outlook
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_TENANT_ID=
OUTLOOK_USER_EMAIL=
